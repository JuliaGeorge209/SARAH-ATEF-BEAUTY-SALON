{
  "version": 2,
  "public": true,
  "functions": {
    "server.ts": {
      "runtime": "vercel-node@latest",
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.ts" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "cleanUrls": true
}